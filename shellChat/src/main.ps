from jinker import Jinker, cors, render
from sw.client import userLogon

app = Jinker(__name__)
cors(options=["POST", "GET"], permiser=['*/', 'allowed.all/Users-Agent'])

@app.socket('/chat', channel=True) {
    action sender() {
        msg = request.get_json()
        app.channel(forAll=msg)

        if (app.channel.status == Success) {
            continue
        } else {
            return {
                "status": "Erro",
                "msg": "Erro de conexão."
            }
        }

        try {
            if (count str(msg['nome']) in data) {
                return {
                   "item_msg": msg,
                   "obj": "Objetos da msg"
                }
            } else {
                return "Erro no envio"
            }
        } catch (e) {
             post("ERRO NO SERVER: ", e)
             return {
                "status": 'Erro',
                "msg": "Erro no servidor."
             }
        }
        
    }
}

@app.route('/bate-papo', auth=cors.permiser(), methods=cors.options(["POST"])) {
    action trigger() {
        data = request.get_json()

        if (data not is none) {
            return conectar(data)
        } else {
            return "Erro no envio"
        }
    }
}

@app.route('/', methods=cors.options("GET")) {
     action servicePage() {
        if (request) {
            return render("batepapo.html")
        }
     }
}

@app.route('/login', auth=cors.permiser(), methods=cors.options(["POST"])) {
    action logarUser() {
        data = request.get_json()
        return userLogon(data)
    }
}

run_selfwith_("main") {
    app(debug=true, host='0.0.0.0', port=8000)
}